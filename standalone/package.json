{
  "name": "oauth2apilocal-standalone",
  "version": "1.0.0",
  "description": "Standalone cross-platform OAuth2 API Gateway for GitHub Copilot and Gemini Pro",
  "main": "dist/standalone.js",
  "bin": {
    "oauth2apilocal": "dist/standalone.js"
  },
  "scripts": {
    "build": "node esbuild.standalone.js",
    "build:prod": "node esbuild.standalone.js --production",
    "test": "jest",
    "package": "pkg dist/standalone.js --out-path=bin",
    "clean": "rm -rf dist bin"
  },
  "keywords": [
    "oauth2",
    "api-gateway",
    "copilot",
    "gemini",
    "openai",
    "anthropic",
    "llm",
    "proxy"
  ],
  "author": "Suhaib Bin Younis",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "minimist": "^1.2.8",
    "selfsigned": "^5.5.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "@types/minimist": "^1.2.5",
    "@types/node": "^25.2.3",
    "@types/ws": "^8.18.1",
    "@yao-pkg/pkg": "^5.15.0",
    "esbuild": "^0.27.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "5.9.3"
  },
  "pkg": {
    "assets": [],
    "targets": [
      "node18-macos-x64",
      "node18-win-x64",
      "node18-linux-x64"
    ],
    "outputPath": "bin"
  }
}
